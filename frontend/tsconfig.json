{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": "./src",
    "paths": {
      // Основные алиасы для папок
      "@api/*": [
        "api/*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@modules/*": [
        "modules/*"
      ],
      "@shared/*": [
        "shared/*"
      ],
      "@domains/*": [
        "domains/*"
      ],
      // Алиасы для index.ts файлов
      "@api": [
        "src/api/index.ts"
      ],
      "@components": [
        "src/components/index.ts"
      ],
      "@domains": [
        "src/domains/index.ts"
      ],
      "@modules": [
        "src/modules/index.ts"
      ],
      "@services": [
        "src/services/index.ts"
      ],
      // shadcn костыль
      "@/components/*": [
        "/*"
      ],
      "@/components": [
        "components/index.ts"
      ],
      "@/shared/lib/*": [
        "shared/lib/*"
      ],
      "@/shared/lib/utils": [
        "shared/lib/utils.ts"
      ],
      "@/shared/hooks/*": [
        "shared/hooks/*"
      ],
      "@/shared/hooks": [
        "shared/hooks/index.ts"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
